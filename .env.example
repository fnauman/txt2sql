# Default: the scripts load .env from the current working directory.
# Optional override: choose exactly one alternate source instead.
#   --env-file=/absolute/or/relative/path/.env
#   --env-dir=/absolute/or/relative/path
#   --use-home-env
# Or via environment variables:
#   ENV_FILE=/path/to/.env
#   ENV_DIR=/path/to/folder
#   USE_HOME_ENV=1

OPENAI_API_KEY=sk-your-key-here
MODEL_NAME=gpt-5.4-mini

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=demo_retail
# Optional for local Docker Compose only. Defaults to DB_PASSWORD when unset.
# MARIADB_ROOT_PASSWORD=secret

# Optional:
# DB_SOCKET=/var/run/mysqld/mysqld.sock
# OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
