  "metrics": [
    {
      "name": "net_sales",
      "synonyms": [
        "net sales",
        "sales",
        "sale",
        "revenue",
        "buyers",
        "biggest buyers",
        "top buyers"
      ],
      "preferred_expression": "COALESCE(SalesDocument.NetAmount, 0)",
      "preferred_columns": [
        "SalesDocument.NetAmount"
      ],
      "grain": "sales_document",
      "preferred_tables": [
        "SalesDocument",
        "Customer"
      ],
      "notes": [
        "For document-level sales/revenue rankings, prefer SalesDocument.NetAmount over payable, bill total, subtotal, or gross columns."
      ]
    },
    {
      "name": "line_net_sales",
      "synonyms": [
        "product sales",
        "sku sales",
        "item sales",
        "merchandise sales",
        "brand sales",
        "category sales",
        "campaign sales"
      ],
      "preferred_expression": "COALESCE(SalesDocumentLine.NetAmount, 0)",
      "preferred_columns": [
        "SalesDocumentLine.NetAmount"
      ],
      "grain": "sales_document_line",
      "preferred_tables": [
        "SalesDocumentLine",
        "Product",
        "SalesDocument"
      ],
      "notes": [
        "Use sales document lines when sales/revenue is filtered or grouped by brand, product category, campaign, product, or SKU."
      ]
    },
    {
      "name": "quantity_sold",
      "synonyms": [
        "quantity sold",
        "qty sold",
        "units sold",
        "sold",
        "sell",
        "moved",
        "movement",
        "stopped selling"
      ],
      "preferred_expression": "COALESCE(SalesDocumentLine.Quantity, 0)",
      "preferred_columns": [
        "SalesDocumentLine.Quantity"
      ],
      "grain": "sales_document_line",
      "preferred_tables": [
        "SalesDocumentLine",
        "Product",
        "SalesDocument"
      ],
      "notes": [
        "Use SalesDocumentLine for product-level quantity analysis."
      ]
    },
    {
      "name": "document_count",
      "synonyms": [
        "document count",
        "invoice count",
        "order count",
        "used the most",
        "most used"
      ],
      "preferred_expression": "COUNT(*)",
      "preferred_columns": [
        "SalesDocument.SalesDocumentId"
      ],
      "grain": "sales_document",
      "preferred_tables": [
        "SalesDocument",
        "DocumentType"
      ],
      "notes": [
        "For document type/class questions, group by DocumentTypeName, not DocumentTypeClass."
      ]
    },
    {
      "name": "debit_amount",
      "synonyms": [
        "debit",
        "debits",
        "debit amount",
        "biggest debits"
      ],
      "preferred_expression": "COALESCE(AccountingPosting.DebitAmount, 0)",
      "preferred_columns": [
        "AccountingPosting.DebitAmount"
      ],
      "grain": "accounting_posting",
      "preferred_tables": [
        "AccountingPosting",
        "LedgerAccount",
        "SalesDocument"
      ],
      "notes": [
        "Use accounting postings with LedgerAccount for ledger debit analysis."
      ]
    },
    {
      "name": "credit_amount",
      "synonyms": [
        "credit",
        "credits",
        "credit amount",
        "biggest credits"
      ],
      "preferred_expression": "COALESCE(AccountingPosting.CreditAmount, 0)",
      "preferred_columns": [
        "AccountingPosting.CreditAmount"
      ],
      "grain": "accounting_posting",
      "preferred_tables": [
        "AccountingPosting",
        "LedgerAccount",
        "SalesDocument"
      ],
      "notes": [
        "Use accounting postings with LedgerAccount for ledger credit analysis."
      ]
    },
    {
      "name": "missing_accounting_postings",
      "synonyms": [
        "without postings",
        "never made it into accounting postings",
        "missing postings"
      ],
      "preferred_expression": "COUNT(*)",
      "preferred_columns": [
        "SalesDocument.SalesDocumentId",
        "AccountingPosting.AccountingPostingId"
      ],
      "grain": "sales_document",
      "preferred_tables": [
        "SalesDocument",
        "AccountingPosting"
      ],
      "notes": [
        "Use an anti-join from SalesDocument to AccountingPosting for documents without postings."
      ]
    }
  ],
  "filter_hints": [
    {
      "name": "demo_product_terms",
      "synonyms": [
        "sparkling water",
        "protein bar",
        "cold brew",
        "trail mix"
      ],
      "target_table": "Product",
      "target_columns": [
        "Product.ProductName",
        "Product.ProductCode",
        "Product.ProductTags",
        "SalesDocumentLine.ProductNameSnapshot"
      ],
      "operator": "OR_LIKE",
      "notes": [
        "Treat these as alternative product search terms. Combine them with OR, not AND."
      ]
    },
    {
      "name": "product_category_terms",
      "synonyms": [
        "beverages",
        "snacks",
        "pantry",
        "household"
      ],
      "target_table": "ProductCategory",
      "target_columns": [
        "ProductCategory.CategoryName",
        "ProductCategory.CategoryCode"
      ],
      "operator": "OR_LIKE",
      "notes": [
        "Treat these as product category search terms. Combine them with OR LIKE filters against ProductCategory columns."
      ]
    }
  ],
