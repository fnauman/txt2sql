  "join_paths": [
    {
      "name": "document_to_customer",
      "tables": [
        "SalesDocument",
        "Customer"
      ],
      "join_sql": "SalesDocument.CustomerId = Customer.CustomerId"
    },
    {
      "name": "document_to_location",
      "tables": [
        "SalesDocument",
        "StoreLocation"
      ],
      "join_sql": "SalesDocument.StoreLocationId = StoreLocation.StoreLocationId"
    },
    {
      "name": "document_to_document_type",
      "tables": [
        "SalesDocument",
        "DocumentType"
      ],
      "join_sql": "SalesDocument.DocumentTypeId = DocumentType.DocumentTypeId"
    },
    {
      "name": "document_line_to_product",
      "tables": [
        "SalesDocumentLine",
        "Product"
      ],
      "join_sql": "SalesDocumentLine.ProductId = Product.ProductId"
    },
    {
      "name": "document_line_to_document",
      "tables": [
        "SalesDocumentLine",
        "SalesDocument"
      ],
      "join_sql": "SalesDocumentLine.SalesDocumentId = SalesDocument.SalesDocumentId"
    },
    {
      "name": "posting_to_account",
      "tables": [
        "AccountingPosting",
        "LedgerAccount"
      ],
      "join_sql": "AccountingPosting.LedgerAccountId = LedgerAccount.LedgerAccountId"
    },
    {
      "name": "posting_to_document",
      "tables": [
        "AccountingPosting",
        "SalesDocument"
      ],
      "join_sql": "AccountingPosting.SalesDocumentId = SalesDocument.SalesDocumentId"
    },
    {
      "name": "product_to_campaign",
      "tables": [
        "Product",
        "Campaign"
      ],
      "join_sql": "Product.CampaignId = Campaign.CampaignId"
    },
    {
      "name": "product_to_category",
      "tables": [
        "Product",
        "ProductCategory"
      ],
      "join_sql": "Product.ProductCategoryId = ProductCategory.ProductCategoryId"
    },
    {
      "name": "product_to_brand",
      "tables": [
        "Product",
        "Brand"
      ],
      "join_sql": "Product.BrandId = Brand.BrandId"
    },
    {
      "name": "product_brand_to_product",
      "tables": [
        "ProductBrand",
        "Product"
      ],
      "join_sql": "ProductBrand.ProductId = Product.ProductId"
    },
    {
      "name": "product_brand_to_brand",
      "tables": [
        "ProductBrand",
        "Brand"
      ],
      "join_sql": "ProductBrand.BrandId = Brand.BrandId"
    },
    {
      "name": "brand_to_category",
      "tables": [
        "Brand",
        "ProductCategory"
      ],
      "join_sql": "Brand.ProductCategoryId = ProductCategory.ProductCategoryId"
    }
  ],
  "clarification_rules": [
    {
      "trigger": "revenue",
      "questions": [
        "Do you want document-level net sales, line-level net sales, bill total, or subtotal?"
      ]
    }
  ]
}
